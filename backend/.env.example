# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=mysql://root:password@localhost:3306/real_estate_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-here

# S3 / CDN
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=real-estate-ai
AWS_CDN_URL=https://cdn.realestate-ai.dev
AWS_ENDPOINT=https://s3.example.com

# WhatsApp Business Cloud API
WA_ENABLED=false
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=your-verify-token

# AI: Anthropic Claude API (listing parser)
ANTHROPIC_API_KEY=your-anthropic-key

# AI: Google Gemini (image enhancement)
GEMINI_API_KEY=your-gemini-key

# Sync: Portal A (WordPress/Houzez)
PORTAL_A_BASE_URL=https://portal-a.example.com
PORTAL_A_USERNAME=api-user
PORTAL_A_PASSWORD=api-password

# Sync: Portal B (Listing Aggregator)
PORTAL_B_API_URL=https://api.portal-b.example.com
PORTAL_B_CLIENT_KEY=your-client-key

# Lark / Feishu CRM
LARK_APP_ID=your-app-id
LARK_APP_SECRET=your-app-secret

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=Real Estate AI <no-reply@realestate-ai.dev>
